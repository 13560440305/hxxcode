{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "编译扩展",
      "type": "shell",
      "command": "npm run compile",
      "options": {
        "cwd": "${workspaceFolder}/src",
        "shell": {
          "executable": "cmd.exe",
          "args": ["/d", "/c"]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc",
      "detail": "运行 tsc 编译 TypeScript 源码"
    }
  ]
}
