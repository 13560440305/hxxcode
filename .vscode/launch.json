{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "运行扩展",
      "type": "extensionHost",
      "request": "launch",
      "title": "启动 Extension Development Host",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/src"
      ],
      "outFiles": [
        "${workspaceFolder}/src/out/**/*.js"
      ],
      "preLaunchTask": "编译扩展",
      "sourceMaps": true
    }
  ]
}
