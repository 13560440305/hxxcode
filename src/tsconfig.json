{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "outDir": "./out",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node16",
    "sourceMap": true,
    "lib": ["ES2022"],
    "declaration": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "out", "webview-ui"]
}
